# Tesseract API — environment template
# Copy this file to `.env` at the repo root (or apps/api/.env) and fill in real values.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/tesseract
DIRECT_URL=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
ATTENDANCE_JWT_SECRET=change-me-too
ATTENDANCE_TOKEN_EXPIRES_IN=8h
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ENABLE_DEV_AUTH=true

# ── Origins ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5001
ALLOWED_ORIGINS=http://localhost:5173
COOKIE_DOMAIN=

# ── Admin bootstrap ────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_NAME=
SEED_ADMIN_EMAIL=

# ── Email (Brevo) ──────────────────────────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=
EMAIL_REPLY_TO=

# ── Cloudinary (uploads) ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SEO / external ─────────────────────────────────────────────────────────
INDEXNOW_KEY=
# Optional WhatsApp invite URL injected into the verified-user welcome email.
INVITE_LINK_WH=

# ── Schedulers + sockets ───────────────────────────────────────────────────
ENABLE_BACKGROUND_SCHEDULERS=true
EVENT_STATUS_INTERVAL_MS=
ENABLE_DB_KEEPALIVE=
DB_KEEPALIVE_INTERVAL_MS=
SOCKET_PING_TIMEOUT_MS=
SOCKET_PING_INTERVAL_MS=
ENABLE_REQUEST_LOGGING=

# ── Optional ───────────────────────────────────────────────────────────────
API_BASE_URL=
PUBLIC_API_BASE_URL=
RENDER_EXTERNAL_URL=
