APP_NAME=Tesseract API
APP_ENV=development
PORT=8000
API_PREFIX=/api/v1
FRONTEND_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tesseract?schema=public
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=<CHANGE_ME>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_PEPPER=<CHANGE_ME>
OTP_REQUEST_LIMIT_PER_IP=3
OTP_REQUEST_LIMIT_PER_EMAIL=5
OTP_VERIFY_LIMIT_PER_CHALLENGE=5
USER_RATE_LIMIT_PER_MINUTE=60

REFRESH_COOKIE_NAME=tesseract_refresh
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

EMAIL_PROVIDER=console
SEED_ADMIN_EMAIL=admin@ds.study.iitm.ac.in
SEED_ADMIN_NAME=Tesseract Admin
SEED_ADMIN_PASSWORD=Dk261135@
GOOGLE_CLIENT_ID=
