generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  guest
  member
  core
  admin
}

enum MembershipStatus {
  pending
  approved
  rejected
}

enum EventStatus {
  upcoming
  live
  completed
  past
  cancelled
}

enum EventCategory {
  hackathon
  quiz
  meetup
  workshop
  tournament
  social
}

enum ParticipantStatus {
  registered
  joined
  waitlisted
  attended
  cancelled
}

enum RegistrationType {
  PARTICIPANT
  GUEST
}

enum TeamRole {
  LEADER
  MEMBER
}

enum GuestRole {
  CHIEF_GUEST
  SPEAKER
  JUDGE
  SPECIAL_GUEST
}

enum GameDifficulty {
  easy
  medium
  hard
  nightmare
}

enum NotificationKind {
  info
  success
  warning
  event
  game
}

enum FlagCategory {
  admin_gate
  user_pref
}

enum FlagValueType {
  bool
  int
  string
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  role            Role      @default(guest)
  rollNumber      String?
  avatarUrl       String?
  bio             String?
  passwordHash    String?
  googleSub       String?   @unique
  xp              Int       @default(0)
  level           String    @default("Bronze")
  streak          Int       @default(0)
  joinedAt        DateTime  @default(now())
  verifiedAt      DateTime?
  lastSeenAt      DateTime?
  lastLoginAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  phone            String?
  course           String?
  branch           String?
  year             String?
  profileCompleted Boolean  @default(false)

  refreshSessions RefreshSession[]
  membershipRequests MembershipRequest[] @relation("MembershipRequestUser")
  reviewedMembershipRequests MembershipRequest[] @relation("MembershipRequestReviewer")
  eventParticipants EventParticipant[]
  gameScores      GameScore[]
  activityLogs    ActivityLog[] @relation("ActivitySubject")
  actedLogs       ActivityLog[] @relation("ActivityActor")
  notifications   Notification[]
  featureOverrides UserFeatureOverride[] @relation("FeatureOverrideUser")
  setFeatureOverrides UserFeatureOverride[] @relation("FeatureOverrideSetter")
  suspensions     UserSuspension[] @relation("SuspendedUser")
  issuedSuspensions UserSuspension[] @relation("SuspensionIssuer")
  liftedSuspensions UserSuspension[] @relation("SuspensionLifter")
  auditLogs       AdminAuditLog[]
  createdEvents   Event[] @relation("EventCreator")
  createdGames    Game[] @relation("GameCreator")
  bestGames       Game[] @relation("BestPlayer")
  eventRegistrations EventRegistration[]
  eventInvitations   EventInvitation[]
  announcements      Announcement[]

  @@index([email])
  @@index([role, deletedAt])
}

model OtpChallenge {
  id          String    @id @default(uuid())
  email       String
  otpHash     String
  expiresAt   DateTime
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  consumedAt  DateTime?
  requestIp   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([expiresAt])
}

model RefreshSession {
  id              String    @id @default(uuid())
  userId          String
  sessionFamilyId String
  tokenHash       String    @unique
  userAgent       String?
  ipAddress       String?
  expiresAt       DateTime
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  rotatedFromId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionFamilyId])
  @@index([expiresAt])
}

model MembershipRequest {
  id           String           @id @default(uuid())
  userId       String
  status       MembershipStatus @default(pending)
  note         String?
  reviewerNote String?
  requestedAt  DateTime         @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user     User @relation("MembershipRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("MembershipRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model Event {
  id              String        @id @default(uuid())
  title           String
  description     String
  coverUrl        String?
  category        EventCategory
  status          EventStatus   @default(upcoming)
  startsAt        DateTime
  endsAt          DateTime
  location        String
  capacity        Int
  registeredCount Int           @default(0)
  xpReward        Int           @default(0)
  organizers      Json          @default("[]")
  tags            Json          @default("[]")
  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  slug                  String?   @unique
  shortDescription      String?
  agenda                String?
  highlights            String?
  learningOutcomes      String?
  targetAudience        String?
  prerequisites         String?
  speakers              Json      @default("[]")
  resources             Json      @default("[]")
  faqs                  Json      @default("[]")
  imageGallery          Json      @default("[]")
  videoUrl              String?
  venue                 String?
  eventType             String?
  featured              Boolean   @default(false)
  allowLateRegistration Boolean   @default(false)
  eventDays             Int       @default(1)
  dayLabels             Json      @default("[]")
  registrationFields    Json      @default("[]")
  registrationStartDate DateTime?
  registrationEndDate   DateTime?
  teamRegistration      Boolean   @default(false)
  teamMinSize           Int       @default(1)
  teamMaxSize           Int       @default(5)

  createdBy User? @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  participants EventParticipant[]
  registrations EventRegistration[]
  teams         EventTeam[]
  invitations   EventInvitation[]

  @@index([title])
  @@index([category])
  @@index([status])
  @@index([startsAt])
  @@index([slug])
}

model EventParticipant {
  id         String            @id @default(uuid())
  eventId    String
  userId     String
  status     ParticipantStatus @default(registered)
  joinedAt   DateTime          @default(now())
  attendedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model Game {
  id            String         @id @default(uuid())
  name          String
  tagline       String
  coverUrl      String?
  emoji         String         @default("🎮")
  category      String
  difficulty    GameDifficulty
  playersOnline Int            @default(0)
  highScore     Int            @default(0)
  bestPlayerId  String?
  description   String
  howToPlay     Json           @default("[]")
  rules         Json           @default("[]")
  xpReward      Int            @default(0)
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  bestPlayer User? @relation("BestPlayer", fields: [bestPlayerId], references: [id], onDelete: SetNull)
  createdBy  User? @relation("GameCreator", fields: [createdById], references: [id], onDelete: SetNull)
  scores     GameScore[]

  @@index([name])
  @@index([category])
  @@index([difficulty])
}

model GameScore {
  id             String   @id @default(uuid())
  gameId         String
  userId         String
  score          Int
  idempotencyKey String
  submittedAt    DateTime @default(now())
  isPersonalBest Boolean  @default(false)
  xpAwarded      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId, idempotencyKey])
  @@index([gameId])
  @@index([userId])
  @@index([score])
}

model ActivityLog {
  id            String   @id @default(uuid())
  actorUserId   String?
  subjectUserId String?
  action        String
  title         String
  description   String?
  meta          Json     @default("{}")
  xpDelta       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  actorUser   User? @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  subjectUser User? @relation("ActivitySubject", fields: [subjectUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([subjectUserId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  body      String
  kind      NotificationKind @default(info)
  readAt    DateTime?
  meta      Json             @default("{}")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FeatureFlag {
  id           String        @id @default(uuid())
  key          String        @unique
  displayName  String
  description  String?
  category     FlagCategory
  valueType    FlagValueType @default(bool)
  defaultValue Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  overrides UserFeatureOverride[]

  @@index([key])
  @@index([category])
}

model UserFeatureOverride {
  id        String   @id @default(uuid())
  userId    String
  flagKey   String
  value     Json
  setById   String
  setAt     DateTime @default(now())
  reason    String?

  user  User @relation("FeatureOverrideUser", fields: [userId], references: [id], onDelete: Cascade)
  setBy User @relation("FeatureOverrideSetter", fields: [setById], references: [id], onDelete: Cascade)
  flag  FeatureFlag @relation(fields: [flagKey], references: [key], onDelete: Cascade)

  @@unique([userId, flagKey])
  @@index([userId])
  @@index([flagKey])
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  note       String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
}

model UserSuspension {
  id          String    @id @default(uuid())
  userId      String
  suspendedBy String
  reason      String
  expiresAt   DateTime?
  liftedAt    DateTime?
  liftedBy    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user            User @relation("SuspendedUser", fields: [userId], references: [id], onDelete: Cascade)
  suspendedByUser User @relation("SuspensionIssuer", fields: [suspendedBy], references: [id], onDelete: Cascade)
  liftedByUser    User? @relation("SuspensionLifter", fields: [liftedBy], references: [id], onDelete: SetNull)

  @@index([userId, liftedAt, expiresAt])
}

model EventRegistration {
  id                   String           @id @default(uuid())
  eventId              String
  userId               String
  registrationType     RegistrationType @default(PARTICIPANT)
  customFieldResponses Json?
  attendanceToken      String?
  registeredAt         DateTime         @default(now())
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  event          Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMembership EventTeamMember?
  dayAttendance  DayAttendance[]

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EventTeam {
  id         String   @id @default(uuid())
  eventId    String
  teamName   String
  inviteCode String   @unique
  leaderId   String
  isLocked   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event   Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  members EventTeamMember[]

  @@unique([eventId, teamName])
  @@index([eventId])
  @@index([inviteCode])
}

model EventTeamMember {
  id             String   @id @default(uuid())
  teamId         String
  registrationId String   @unique
  userId         String
  role           TeamRole @default(MEMBER)
  joinedAt       DateTime @default(now())

  team         EventTeam         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  registration EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
}

model DayAttendance {
  id             String    @id @default(uuid())
  registrationId String
  dayNumber      Int
  attended       Boolean   @default(false)
  scannedAt      DateTime?

  registration EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, dayNumber])
  @@index([registrationId])
}

model EventInvitation {
  id          String     @id @default(uuid())
  eventId     String
  userId      String?
  email       String?
  guestRole   GuestRole
  accepted    Boolean    @default(false)
  acceptedAt  DateTime?
  revokedAt   DateTime?
  certificate Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  priority    Int      @default(0)
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([publishedAt])
}
