{
  "name": "tesseract",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:frontend": "next dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:backend": "npm --prefix backend test",
    "lint:backend": "npm --prefix backend run lint",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run lint:backend && npm run test:backend"
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "framer-motion": "11.11.9",
    "zustand": "5.0.0",
    "axios": "1.7.7",
    "react-hot-toast": "2.4.1",
    "lucide-react": "0.453.0",
    "clsx": "2.1.1",
    "tailwind-merge": "2.5.4"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.15"
  }
}
