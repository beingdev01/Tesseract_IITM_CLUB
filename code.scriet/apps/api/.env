# =================================================================
# Tesseract API — local dev environment
# =================================================================
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5001

# CSV of accepted browser origins (production CORS allowlist).
# In dev, localhost/127.0.0.1/private LAN ranges are auto-allowed.
ALLOWED_ORIGINS=

# Cookie domain for the tesseract_session cookie. Leave empty for localhost.
# In production set to ".tesseract.example" so the cookie is shared across subdomains.
COOKIE_DOMAIN=

# JWT signing secret (any random string for dev)
JWT_SECRET=dev_only_jwt_secret_change_in_prod_d8a7f6e5c4b3a2

# Super admin: drives the runtime isSuperAdmin flag (audit log visibility, settings, etc.)
SUPER_ADMIN_EMAIL=24f2007465@ds.study.iitm.ac.in
SUPER_ADMIN_NAME=Lakshya

# Bootstrap admin: the email below gets auto-promoted to ADMIN on first OAuth login.
# Idempotent — once promoted (or higher), it's a no-op. Often the same as SUPER_ADMIN_EMAIL.
SEED_ADMIN_EMAIL=24f2007465@ds.study.iitm.ac.in

# Database — local Postgres (created via `createdb tesseract_iitm`).
DATABASE_URL=postgresql://lakshya@localhost:5432/tesseract_iitm
DIRECT_URL=postgresql://lakshya@localhost:5432/tesseract_iitm

# OAuth — required for production sign-in. Leave blank in pure-dev mode (use ENABLE_DEV_AUTH).
GOOGLE_CLIENT_ID=562143691928-3fvhek4cs6tvpf6ucpiua98q2op0uag6.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# Cloudinary — required for avatar/certificate/event image uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Brevo — email delivery (optional in dev)
BREVO_API_KEY=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
EMAIL_FROM=code.scriet@codescriet.dev
EMAIL_FROM_NAME=code.scriet
# Dev features
ENABLE_DEV_AUTH=true
ENABLE_DB_KEEPALIVE=false
ENABLE_BACKGROUND_SCHEDULERS=false
