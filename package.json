{
  "name": "tesseract-iitm-club-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bash ./scripts/free-dev-ports.sh && concurrently -n \"API,WEB\" -c \"blue,green\" \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "start": "npm run build && npm run start:prod",
    "start:prod": "NODE_ENV=production npm run start --workspace=apps/api",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/api",
    "web": "npm run dev --workspace=apps/web",
    "api": "npm run dev --workspace=apps/api",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:stability": "node --import tsx --test apps/api/src/utils/*.test.ts apps/web/tests/*.test.ts",
    "setup": "npm install && npm run db:migrate && npm run db:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.27",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "prisma": "^5.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0"
  },
  "overrides": {
    "qs": "6.15.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
